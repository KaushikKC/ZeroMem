{
  "name": "zeromem",
  "version": "0.1.0",
  "description": "ZeroMem — Git-for-agent-memory on 0G. Auto-recall + auto-capture + memory tools.",
  "entry": "dist/index.js",
  "factory": "createZeroMemPlugin",
